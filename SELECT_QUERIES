--BASIC DATA RETRIEVAL
-- retrieving all customer data
select * 
from dbo.customers

-- retrieve all order data
Select * 
from orders

-- Retrieving certain columns (customer names, their country, and their score) & 'as' to rename the column names
Select
first_name as First_Name,
country as Country,
score as Score
from dbo.customers



-- WHERE STATEMENT
-- filtering data with a WHERE statement ( list customers with a score greater than 500)
Select 
first_name,
score
from dbo.customers
where score > 500

-- filtering data with a WHERE statement ( list customers with a score greater than 0)
Select
*
from dbo.customers
where score > 0

-- filtering data with a WHERE statement ( list customers with a score  equal to 0)
Select
* 
From dbo.customers
where score = 0

-- filtering data with a WHERE statement ( list customers who are from Germany)
-- reminder: if you are filtering for a text, it must be in 'xxx' (single quotations)
Select
*
from dbo.customers
where country = 'Germany'



--ORDER BY
-- sorting data with the ORDER BY (ASC -> Lowest to Highest, DESC -> Highest to Lowest)
-- Retrieve all customer data, with Scores descending
Select * 
From DBO.customers
Order by Score DESC

-- Retrieve all customer data, with lowest score first
Select * 
From DBO.customers
Order by Score ASC

-- using nested sorting with order by
-- Country asc and score desc (sorts countring in ABC order, with highest score from said country first)
Select *
from dbo.customers
ORDER BY country ASC, score desc



--GROUP BY (aggragate data)
--Find TOTAL (SUM) score by country, order by the score highest to lowest
Select
country,
sum(score) as Country_Score -- <- adding in a column name for the table // Score is the column being aggragated/manipulated (sum)
from dbo.customers
group by country -- <- The non-aggragate column is whats being grouped by
order by sum(score) Desc 

--Find TOTAL (SUM) score and total number of customer by country, order by the score highest to lowest
select
Country,
Sum(score) as Total_Score,
Count(first_name) as Customer_Count
From DBO.customers
group by country
order by sum(score) Desc



--Having
--Filtering Aggregated Data
-- Retrieve countries with a total score greater than 800
select
Country,
sum(score) AS TOTAL_SCORE
from DBO.CUSTOMERS
group by country
having sum(score) >800
ORDER BY SUM(SCORE) DESC

-- RETRIEVE COUNTRIES WITH A TOTAL SCORE GREATER THAN 800, REMOVING INDIVIDUAL SCORES LESS THAN 400
SELECT
COUNTRY,
SUM(SCORE) AS TOTAL_SCORE
FROM DBO.customers
WHERE SCORE > 400
GROUP BY country
HAVING SUM(SCORE) > 800
ORDER BY SUM(SCORE) DESC

-- FIND THE AVERAGE SCORE FOR EACH COUNTRY CONSIDERING ONLY CUSTOMERS WITH A SCORE NOT EQUAL TO 0
--AND RETURN ONLY THOSE COUNTRIES WITH AN AVERAGE SCORE GREATER THAN 430
SELECT
COUNTRY,
AVG(SCORE) AS AVG_SCORE
FROM DBO.customers
WHERE SCORE != 0  -- THE '!=' MEANS NOT EQUAL TO
GROUP BY country
HAVING AVG(SCORE) >430
ORDER BY AVG(SCORE) DESC



---DISTINCT
--REMOVES DUPLICATES/ REPEATED VALUES
--RETREIEVE UNIQUE LIST OF COUNTRIES FROM THE CUSTOMERS TABLE
SELECT DISTINCT
COUNTRY
FROM DBO.customers



--TOP
--TO LIMIT DATA RETRIEVED // RESTRICTS THE NUMBER OF ROWS RETRIEVED
--RETRIEVE THE TOP 3 CUSTOMERS WITH THE HIGHEST SCORE
SELECT TOP 3 
*
FROM DBO.customers
ORDER BY SCORE DESC

-- RETRIEVE THE LOWEST 2 CUSTOMERS BASED ON THEIR SCORE, EXCLUDING ANYONE WITH A SCORE OF 0
SELECT TOP 2
*
FROM DBO.customers
WHERE SCORE != 0
ORDER BY SCORE ASC

-- GET THE TWO MOST RECENT ORDERS (DBO.ORDERS) 
SELECT TOP 2
* FROM DBO.ORDERS
ORDER BY order_date DESC

